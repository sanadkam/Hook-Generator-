# ============================================
# HookLab Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- Anthropic (required) ---
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (required for auth & profiles) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe (required for billing) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — map your Stripe prices to plan tiers
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# Payment link for upgrade button (optional)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link_here

# --- App URL (required for SEO, redirects, Stripe returns) ---
NEXT_PUBLIC_SITE_URL=https://hook-generator-tau.vercel.app
NEXT_PUBLIC_APP_URL=https://hook-generator-tau.vercel.app
